# =============================================================================
# Research Synthesizer / MedLit Agent Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =============================================================================
# API Keys
# =============================================================================
GEMINI_API_KEY=your-gemini-api-key-here

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=research
POSTGRES_PASSWORD=research_password
POSTGRES_DB=research_synthesizer

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password
NEO4J_DATABASE=neo4j

# Redis Configuration
REDIS_URL=redis://localhost:6379

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio_access
MINIO_SECRET_KEY=minio_secret
MINIO_BUCKET=research-papers

# =============================================================================
# Application Settings
# =============================================================================
LOG_LEVEL=INFO
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000

# Rate Limiting
GEMINI_REQUESTS_PER_MINUTE=60
GEMINI_TOKENS_PER_MINUTE=1000000

# Budget Tracking
DAILY_BUDGET_USD=10.0
MONTHLY_BUDGET_USD=200.0

# =============================================================================
# Authentication (IMPORTANT: Generate secure secrets for production!)
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Medical AI / MedGemma Settings
# =============================================================================
# Path to local MedGemma model (download with: ./scripts/download_model.sh)
MEDGEMMA_MODEL_PATH=models/medgemma-4b-it-Q4_K_M.gguf
MEDGEMMA_CONTEXT_LENGTH=8192
USE_LOCAL_MEDGEMMA=true

# PubMed API (get key from: https://www.ncbi.nlm.nih.gov/account/settings/)
PUBMED_API_KEY=
PUBMED_EMAIL=your-email@example.com

# =============================================================================
# Twilio Integration (SMS/Voice for appointments)
# =============================================================================
# Get credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# =============================================================================
# ChromaDB (Local Vector Store)
# =============================================================================
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=medical_papers
MEDICAL_EMBEDDING_MODEL=pritamdeka/S-PubMedBert-MS-MARCO
