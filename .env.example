# =============================================================================
# MedMink / Research Synthesizer Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =============================================================================
# API Keys
# =============================================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=research
POSTGRES_PASSWORD=research_password
POSTGRES_DB=research_synthesizer

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password
NEO4J_DATABASE=neo4j

# Redis Configuration
REDIS_URL=redis://localhost:6379

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio_access
MINIO_SECRET_KEY=minio_secret
MINIO_BUCKET=research-papers
MINIO_SECURE=false

# =============================================================================
# Application Settings
# =============================================================================
LOG_LEVEL=INFO
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000

# Rate Limiting
GEMINI_REQUESTS_PER_MINUTE=60
GEMINI_TOKENS_PER_MINUTE=1000000

# Budget Tracking
DAILY_BUDGET_USD=10.0
MONTHLY_BUDGET_USD=200.0

# =============================================================================
# Authentication (generate secure secrets for production)
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# MedGemma / HAI-DEF model settings
# =============================================================================
# Local inference
MEDGEMMA_MODEL=./models/medgemma-1.5-4b-it
MEDGEMMA_DEVICE=auto
MEDGEMMA_LOAD_IN_4BIT=true
MEDGEMMA_CONTEXT_LENGTH=8192
USE_LOCAL_MEDGEMMA=true

# Modal endpoints (remote GPU inference)
MEDGEMMA_MODAL_URL=
MEDGEMMA_MODAL_MODEL=google/medgemma-27b-it
MEDGEMMA_MULTIMODAL_MODAL_URL=
MEDGEMMA_MULTIMODAL_MODAL_MODEL=google/medgemma-27b-multimodal
TXGEMMA_MODAL_URL=
TXGEMMA_MODAL_MODEL=google/txgemma-9b-chat
CXR_FOUNDATION_MODAL_URL=
DERM_FOUNDATION_MODAL_URL=
PATH_FOUNDATION_MODAL_URL=
HEAR_MODAL_URL=
MEDASR_MODAL_URL=
WHISPER_MODAL_URL=

# PubMed API (get key from: https://www.ncbi.nlm.nih.gov/account/settings/)
PUBMED_API_KEY=
PUBMED_EMAIL=your-email@example.com

# =============================================================================
# ChromaDB (local vector store)
# =============================================================================
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=medical_papers
MEDICAL_EMBEDDING_MODEL=pritamdeka/S-PubMedBert-MS-MARCO

# =============================================================================
# Twilio Integration (SMS/Voice for appointments)
# =============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
